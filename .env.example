# ─────────────────────────────────────────────────────────────
#  OpenClaw Pentester — Variables de entorno
#  Copia este archivo a .env y rellena los valores
#  ⚠️  NUNCA subas .env al repositorio
# ─────────────────────────────────────────────────────────────

# ── Modelo de IA (necesitas al menos uno) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...

# ── Seguridad del gateway de OpenClaw ─────────────────────────
# Genera uno con: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=cambia-esto-por-un-token-seguro

# ── OWASP ZAP ─────────────────────────────────────────────────
ZAP_API_KEY=cambia-esto-por-una-clave-zap

# ── interactsh (OOB payloads) ──────────────────────────────────
# Opcional si usas el servidor self-hosted del docker-compose
INTERACTSH_TOKEN=
